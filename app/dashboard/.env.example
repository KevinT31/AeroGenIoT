# Aurora Noctua dashboard
# Base URL of the backend origin. Do not include /api/v1.
VITE_API_BASE=http://localhost:3000

# Device scope
VITE_DEVICE_ID=AE-01
VITE_FARM_ID=
VITE_PLOT_ID=

# Runtime behavior
VITE_REQUEST_TIMEOUT_MS=12000
VITE_POLL_MS=5000
VITE_STALE_AFTER_MS=90000
VITE_REALTIME_ENABLED=true
VITE_USE_MOCK=false

# Optional bearer token for protected endpoints like /api/v1/readings
VITE_ACCESS_TOKEN=

# Future cloud profile selector
VITE_CLOUD_PROFILE=current

# UI defaults
VITE_DEFAULT_THEME=dark
